<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
    <metadata>
        <version>2.0.0-beta.1</version>
        <id>datatables.net-rowgroup-bs</id>
        <description>This is RowGroup for DataTables with styling for [Bootstrap](https://getbootstrap.com/docs/3.3/)</description>
        <repository type="git" url="https://github.com/DataTables/RowGroup"/>
        <authors>SpryMedia Ltd</authors>
        <projectUrl>http://datatables.net</projectUrl>
        <license type="expression">MIT</license>
        <tags>RowGroup  Row Grouping  Bootstrap  Datatables table</tags>
        <dependencies>
            <dependency id="datatables.net-rowgroup" version="2.0.0-beta.1"/>
            <dependency id="datatables.net-bs" version="3.0.0-0"/>
        </dependencies>
        <contentFiles>
            <files include="**/*" buildAction="Content"/>
        </contentFiles>
        <readme>Readme.md</readme>
    </metadata>
    <files>
        <file src="Readme.md" target=""/>
        <file src="js/rowGroup.bootstrap.js" target="content\Scripts"/>
        <file src="js/rowGroup.bootstrap.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowGroup.bootstrap.min.js" target="content\Scripts"/>
        <file src="js/rowGroup.bootstrap.min.js" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowGroup.bootstrap.min.mjs" target="content\Scripts"/>
        <file src="js/rowGroup.bootstrap.min.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="js/rowGroup.bootstrap.mjs" target="content\Scripts"/>
        <file src="js/rowGroup.bootstrap.mjs" target="contentFiles\any\any\wwwroot\js"/>
        <file src="css/rowGroup.bootstrap.css" target="content\Content"/>
        <file src="css/rowGroup.bootstrap.css" target="contentFiles\any\any\wwwroot\css"/>
        <file src="css/rowGroup.bootstrap.min.css" target="content\Content"/>
        <file src="css/rowGroup.bootstrap.min.css" target="contentFiles\any\any\wwwroot\css"/>
    </files>
</package>
